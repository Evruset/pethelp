{
  "name": "vethelp-clinic-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "e2e": "rm -rf test-results playwright-report allure-results allure-report && next build && playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "e2e:report": "npm run e2e && npm run allure:generate"
  },
  "dependencies": {
    "jose": "^6.0.0",
    "next": "^16.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0"
  }
}
