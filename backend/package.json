{
  "name": "vethelp-mvp1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:dev": "ts-node src/main.ts",
    "test": "jest --runInBand --passWithNoTests",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations/node-pg --migration-file-language js",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations/node-pg --migrations-schema public --migrations-table schema_migrations --single-transaction && node scripts/verify-migration-checksums.cjs --write-missing",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations/node-pg --migrations-schema public --migrations-table schema_migrations --single-transaction",
    "migrate:verify": "node scripts/verify-migration-checksums.cjs",
    "openapi:export": "ts-node scripts/export-openapi.ts",
    "openapi:generate": "npm run build && npm run openapi:export",
    "seed": "ts-node scripts/seed.ts",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.0.0",
    "axios": "^1.7.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "livekit-server-sdk": "^2.15.5",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "jest": "^30.2.0",
    "nock": "^14.0.10",
    "node-pg-migrate": "^8.0.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
